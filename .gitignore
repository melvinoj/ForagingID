# Environment variables (secrets)
.env
.env.*
.envy

# Python
venv/
__pycache__/
*.pyc
*.pyo

# Mac system files
.DS_Store
# AppleDouble resource forks (created on non-native filesystems)
._*

# Claude / AI local configs
.claude/

# Logs
*.log

# IDE/editor files
.vscode/
.idea/

# ── Generated data (never commit) ─────────────────────────────────────────
# SQLite database (trial observations, thumbnails index)
data/foragingid.db
# WAL/shared-memory sidecars — live DB state, never source
data/foragingid.db-wal
data/foragingid.db-shm

# Generated thumbnails (rebuilt from source photos)
data/thumbnails/
# Quarantined thumbnails — image binaries, same class as thumbnails/ above.
# Was tracked by oversight (10,768 files / 188M); untracked 18 Jul 2026.
data/thumbnails_quarantine/

# Triage contact sheets (image binaries) — moved in from ~/Documents/ForagingID
data/triage_sheets/

# Cache and checkpoint files from scan runs
data/cache/
data/checkpoint_*.json

# Upload staging directory
uploads/

# Locally-generated export output (encounter markdown notes, etc.)
exports/

# DB snapshots (binary blobs — project-relative, pruned by rolling retention)
snapshots/

# DB backup/rescue copies (ad hoc pre-fix safety copies, not the live DB)
data/*.bak_*
data/*_backup_*.db
data/*.db.bak

# ── Photos ─────────────────────────────────────────────────────────────────
# Only confirmed/approved photos live in the app folder.
# Raw scan sources stay in ~/Documents/Pictures (Task 2).
# Ignore all direct children of photos/ except confirmed_plants/logs/
# (negating a path requires un-ignoring each ancestor directory too —
# a bare `!photos/confirmed_plants/logs/` has no effect while
# `photos/*` still excludes the confirmed_plants/ parent directory itself)
photos/*
!photos/confirmed_plants/
photos/confirmed_plants/*
!photos/confirmed_plants/logs/
